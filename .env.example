# Copy this file to .env and fill in your values

# Google OAuth credentials (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Sheets service account credentials (paste the entire service-account JSON on one line)
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"expense-tracker@project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Name of the Google Sheet (must be shared with the service account email above)
SPREADSHEET_NAME=Expense Logs

# Strong random secret for signing session tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Public URL of your deployment (no trailing slash)
# For local dev: http://localhost:8000
# For Render: https://your-app-name.onrender.com
BASE_URL=http://localhost:8000

# Set to false in production
DEBUG=true
